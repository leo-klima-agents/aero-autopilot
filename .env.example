# ── aero-autopilot environment ──────────────────────────────────────────────
# Secrets never reach the browser (P7). These are consumed only by:
#   - contracts fork tests   (foundry.toml rpc_endpoints reads env)
#   - packages/core data indexer
#   - apps/keeper
#   - deploy / verify scripts
#   - GitHub Actions repository secrets (data.yml, fork-tests.yml)
# Never referenced anywhere in apps/web.

# Private Base RPC endpoint (fork tests, keeper, indexer)
BASE_RPC_URL=

# Alchemy API key (data indexer enhanced APIs)
ALCHEMY_API_KEY=

# Basescan/Etherscan v2 API key (contract verification)
ETHERSCAN_API_KEY=

# Keeper hot key — mechanical execution only; compromise costs liveness, not funds (P6)
KEEPER_PRIVATE_KEY=

# Deployed diamond address (keeper target)
DIAMOND_ADDRESS=

# Optional secondary RPC the keeper falls back to on provider outage
BASE_RPC_URL_FALLBACK=
